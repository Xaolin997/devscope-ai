generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  empresas MembroEmpresa[]
}

model Empresa {
  id String @id @default(uuid())

  nome            String
  nomeNormalizado String
  criadoPorId     String
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  membros  MembroEmpresa[]
  projetos Projeto[]

  @@unique([criadoPorId, nomeNormalizado])
}

model MembroEmpresa {
  id        String   @id @default(uuid())
  cargo     Cargo    @default(MEMBRO)
  usuarioId String
  empresaId String
  criadoEm  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, empresaId])
}

model Projeto {
  id              String        @id @default(uuid())
  nome            String
  nomeNormalizado String
  descricao       String?
  status          StatusProjeto @default(ATIVO)
  dataInicio      DateTime?
  dataLimite      DateTime?
  empresaId       String
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, nomeNormalizado])
  @@index([empresaId])
}

enum Cargo {
  ADMIN
  GERENTE
  MEMBRO
}

enum StatusProjeto {
  ATIVO
  PAUSADO
  CONCLUIDO
  CANCELADO
}
